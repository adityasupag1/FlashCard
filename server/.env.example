PORT=5000
NODE_ENV=development
MONGO_URI=mongodb://127.0.0.1:27017/flashdeck
JWT_SECRET=your_super_secret_jwt_key_change_me_in_production
JWT_EXPIRE=30d
# Provide ONE of the following AI keys. The server auto-detects which to use.
# OpenAI (preferred)
OPENAI_API_KEY=
# Optional OpenAI-compatible base URL override (e.g., OpenRouter)
# OPENAI_BASE_URL=https://openrouter.ai/api/v1
# Optional OpenAI model override (default: gpt-4o-mini)
OPENAI_MODEL=gpt-4o-mini
# Optional comma-separated fallback models (useful for free providers)
# OPENAI_MODEL_FALLBACKS=google/gemma-4-31b-it:free,openai/gpt-oss-20b:free
# Gemini (Google) - optional fallback, get at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
# Optional Gemini model override (auto-fallbacks are built-in)
GEMINI_MODEL=gemini-2.0-flash
# Anthropic (optional fallback)
ANTHROPIC_API_KEY=
CLIENT_URL=http://localhost:5173
